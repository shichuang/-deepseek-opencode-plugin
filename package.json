{
  "name": "@deepseek/opencode-plugin",
  "version": "0.1.0",
  "description": "DeepSeek Adaptation Plugin for OpenCode — first-class DeepSeek V4 support, Constitution system prompt, multi-provider ecosystem, and cache-optimized prompt layering",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": "./dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "keywords": [
    "opencode",
    "plugin",
    "deepseek",
    "ai",
    "llm",
    "coding-agent"
  ],
  "author": "CodeWhale Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hmbown/CodeWhale.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.11",
    "@opencode-ai/sdk": "^1.17.11"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
